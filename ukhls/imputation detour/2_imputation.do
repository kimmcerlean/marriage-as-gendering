**# Start imputation
********************************************************************************
use "$created_data/ukhls_couples_rectangular_wide.dta", clear

bysort couple_id: gen couples=_n
tab couples

foreach var in dob_year xw_sex xw_memorig xw_sampst{ //
	inspect `var'
	drop if `var' == .
}

mi set wide

mi register imputed total_hours* work_hours* howlng* any_aid* aid_hours* employment_status* jbstat* fimnlabgrs_dv* hubuys* hufrys* huiron* humops* huboss* husits* nkids_dv* marital_status_imp* npens_dv* npn_dv* hhsize* fihhmngrs_dv* gor_dv* urban_dv* tenure_dv* master_religion* disabled_est* sr_health* life_satisfaction* age_youngest_child* year_first_birth_imp hiqual_fixed xw_ethn_dv xw_ukborn father_educ mother_educ father_empstatus mother_empstatus family_structure ever_parent

mi register regular dob_year xw_sex xw_memorig xw_sampst years_observed eligible_rel_start_year eligible_rel_no eligible_end_estimated age_all* respondent_info*

mi xtset, clear
mi stset, clear

// start imputation
#delimit ;

// mimpt chained
mi impute chained

