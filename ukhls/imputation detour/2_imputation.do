********************************************************************************
* Description
********************************************************************************
* This file takes individuals in couples (created step 1 (within imputation subfolder))
* and imputes missing years / variables (esp housework)

********************************************************************************
* First, a few final steps for imputation
********************************************************************************
use "$created_data/ukhls_couples_rectangular_long.dta", clear

// few final explorations and recodes
unique pidp // 42626
unique pidp if hiqual_fixed==. //   1517 (3.5%)
unique pidp if xw_ethn_dv==. //  613
unique pidp if xw_racel_dv==. //  704
unique pidp if xw_ukborn==. //  1486

unique pidp if hiqual_fixed==. | xw_ukborn==. | xw_ethn_dv ==.  // if ALL missing, it's 2629 (6%) - okay so I think I maybe SHOULD impute

tab xw_memorig xw_sampst, m row // are these perfectly correlated? no
tab marital_status_imp partnered_imp, m // only need to use one of these. partnered has more but marital status more precise so use that?

// explore shape of data before imputation
histogram total_hours if total_hours > 0 & total_hours < 80, width(1)
histogram total_hours if total_hours >= 0 & total_hours < 80, width(1)
histogram howlng if howlng < 50, width(1)

// recode duration so none negative (-2 becomes 0)
gen duration = relative_duration+2
browse relative_duration duration
tab duration, m

// why is first / last couple year not unique? Okay I think this is different relationships being tracked outside of eligible one. I don't want to overwrite this. I think I don't this variable, can use the other rel info ones
unique couple_id first_couple_year last_couple_year

sort pidp int_year

// going to attempt to impute this
gen year_first_birth_imp = year_first_birth
replace year_first_birth_imp = . if year_first_birth==0

// After running into errors, I need to make these categorical task variables conditional on being partnered. HOWEVER, that means i need to set them to a value when not partnered for this to work. I think I will do as 0.
tab hufrys marital_status_imp, m
tab marital_status_imp marstat, m

replace marital_status_imp = 1 if marital_status_imp==. & inlist(marstat,2,3) // married
replace marital_status_imp = 2 if marital_status_imp==. & marstat==1 & hufrys!=. //cohab
replace marital_status_imp = 3 if marital_status_imp==. & marstat==4 // separated
replace marital_status_imp = 4 if marital_status_imp==. & marstat==5 // divorced
replace marital_status_imp = 5 if marital_status_imp==. & marstat==6 // widowed

browse pidp couple_id year marital_status_imp hubuys hufrys humops huiron husits huboss mlstat marstat mastat if marital_status_imp==. & hubuys!=.
browse pidp couple_id year marital_status_imp hubuys hufrys humops huiron husits huboss mlstat marstat mastat if inlist(couple_id, 8438, 21040, 46297)
	
foreach var in hubuys hufrys humops huiron husits huboss{
	tab `var' marital_status_imp, m
	gen `var'_v0 = `var'
	replace `var' = 0 if inrange(marital_status_imp,3,6)
	replace `var' = . if `var' !=. & marital_status_imp==.
	tab `var' marital_status_imp, m
}

