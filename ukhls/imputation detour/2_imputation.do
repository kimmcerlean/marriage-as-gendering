* Reshape wide
********************************************************************************
local reshape_vars "total_hours work_hours jbhrs jshrs howlng any_aid aidhrs aid_hours employed employment_status jbstat fimnlabgrs_dv current_parent_status nkids_dv age_youngest_child partnered_imp marital_status_imp npens_dv npn_dv hhsize fihhmngrs_dv gor_dv urban_dv orig_record hiqual_dv nchild_dv partnered marital_status_defacto country_all age_all current_rel_start_year current_rel_end_year ivfio sampst hidp psu strata int_year year aidhh aidxhh husits hubuys hufrys huiron humops huboss tenure_dv housing_status_alt master_religion religion_est empstat_disabled empstat_retired disabled_est sr_health life_satisfaction respondent_info respondent_self current_divorce_status eligible_couple marr_trans"

keep couple_id pidp eligible_partner duration eligible_couple_id eligible_rel_start_year eligible_rel_end_year eligible_rel_status eligible_rel_no min_dur max_dur years_observed  ever_eligible max_eligible_rels first_divorce_year xw_xwdat_dv xw_memorig xw_sampst xw_sex xw_lvag16 xw_agelh xw_lvag14 xw_racel_dv xw_ukborn xw_bornuk_dv mother_empstatus mother_educ father_empstatus father_educ xw_coh1m_dv xw_coh1y_dv xw_evercoh_dv xw_lmar1m_dv xw_lmar1y_dv xw_evermar_dv xw_ch1by_dv xw_anychild_dv xw_ethn_dv  first_year_observed last_year_observed ever_parent year_first_birth year_first_birth_imp num_religion family_structure family_structure14_det first_marr_yr first_cohab_yr first_cohab_end_yr eligible_end_estimated hiqual_fixed dob_year year_transitioned year_transitioned_wave ever_transition in_partner_history birth_timing_rel premarital_birth prior_divorce `reshape_vars' // first_couple_year last_couple_year 

reshape wide `reshape_vars'  ///
, i(couple_id pidp eligible_partner eligible_rel_start_year eligible_rel_end_year eligible_rel_status eligible_rel_no xw_sex) ///
 j(duration)
 
browse couple_id pidp eligible_partner total_hours* howlng* orig_record*

unique couple_id
 
save "$created_data/ukhls_couples_rectangular_wide.dta", replace

